# Public env vars are inlined into the JS bundle at Metro start.
# Restart Expo after changing this file:  pnpm exec expo start -c
#
# Physical phone / tablet (same Wi‑Fi as your Mac):
#   EXPO_PUBLIC_API_URL=http://192.168.x.x:3000
# Android emulator:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
# iOS simulator:
#   EXPO_PUBLIC_API_URL=http://localhost:3000

EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
