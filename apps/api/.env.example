# Runtime connection — presente_app role, RLS enforced
DATABASE_URL=postgres://presente_app:CHANGE_ME@localhost:5432/presente_dev
# Migration connection — table owner (RLS-exempt), used only by pnpm migrate
MIGRATION_DATABASE_URL=postgres://localhost:5432/presente_dev
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=12h
# S3-compatible object storage (Hetzner Object Storage / MinIO / AWS S3)
STORAGE_ENDPOINT=https://fsn1.your-objectstorage.com
STORAGE_REGION=fsn1
STORAGE_BUCKET=presente
STORAGE_ACCESS_KEY_ID=CHANGE_ME
STORAGE_SECRET_ACCESS_KEY=CHANGE_ME
UPLOAD_URL_TTL_SECONDS=900
WEB_URL=http://localhost:5173
# Symmetric key for AES-256 encryption of worker gov IDs + face template ids
GOV_ID_ENC_KEY=CHANGE_ME
