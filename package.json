{
  "name": "presente",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n api,web,mobile -c blue,green,magenta \"pnpm dev:api\" \"pnpm dev:web\" \"pnpm dev:mobile\"",
    "dev:stack": "concurrently -k -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "pnpm --filter @presente/api start:dev",
    "dev:web": "pnpm --filter @presente/web dev",
    "dev:mobile": "pnpm --filter @presente/mobile start",
    "test": "pnpm -r test",
    "build": "pnpm -r build"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
